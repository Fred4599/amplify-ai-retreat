---
const navItems = [
  { label: 'Experience', href: '/#experience' },
  { label: 'Guides', href: '/#guides' },
  { label: 'FAQ', href: '/#faq' },
];
---

<nav aria-label="Main navigation" class="fixed top-4 left-0 right-0 z-50 px-8 lg:px-16 py-3 flex items-center justify-between pointer-events-none">
  <a
    href="/"
    class="pointer-events-auto h-12 pl-2 pr-4 flex items-center justify-center gap-2 rounded-full bg-white/5 backdrop-blur-md border border-white/10"
  >
    <img
      src="/logo.png"
      alt="Amplify AI"
      width="36"
      height="36"
      class="h-9 w-9 shrink-0 object-contain"
    />
    <span class="text-white font-body font-medium text-sm tracking-tight">Amplify</span>
  </a>

  <div class="pointer-events-auto hidden md:flex items-center liquid-glass rounded-full px-1.5 py-1">
    <a
      href="/"
      class="px-4 py-2 text-sm font-medium text-white/90 font-body hover:text-white transition-colors"
    >
      ← Home
    </a>
    {navItems.map((item) => (
      <a
        href={item.href}
        class="px-4 py-2 text-sm font-medium text-white/90 font-body hover:text-white transition-colors"
      >
        {item.label}
      </a>
    ))}
    <span class="bg-white text-black rounded-full px-3.5 py-1.5 text-sm font-medium ml-2">Apply</span>
  </div>

  <a
    href="/"
    class="md:hidden pointer-events-auto liquid-glass rounded-full px-4 py-3 text-white text-sm font-body font-medium"
  >
    ← Home
  </a>
</nav>
