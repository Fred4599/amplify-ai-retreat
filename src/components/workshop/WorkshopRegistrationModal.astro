---
import WorkshopRegistrationForm from './WorkshopRegistrationForm.astro';
import { WORKSHOP } from '../../config/workshop';
---

<div
  id="registration-modal"
  class="fixed inset-0 z-[60] hidden items-end sm:items-center justify-center p-0 sm:p-6"
  role="dialog"
  aria-modal="true"
  aria-labelledby="registration-modal-title"
  hidden
>
  <button
    type="button"
    class="absolute inset-0 bg-black/75 backdrop-blur-sm"
    data-close-registration
    aria-label="Close registration"
  ></button>

  <div
    class="relative w-full sm:max-w-lg max-h-[92svh] overflow-y-auto rounded-t-3xl sm:rounded-3xl border border-white/10 bg-black/95 backdrop-blur-xl shadow-2xl"
  >
    <div class="sticky top-0 z-10 flex items-start justify-between gap-4 border-b border-white/10 bg-black/95 px-6 py-5">
      <div>
        <p class="text-white/50 text-xs font-body uppercase tracking-widest mb-1">
          {WORKSHOP.subtitle}
        </p>
        <h2 id="registration-modal-title" class="text-2xl sm:text-3xl font-heading italic text-white tracking-tight">
          Reserve your spot
        </h2>
        <p class="text-white/60 font-body text-sm mt-1">
          {WORKSHOP.dateLine} · {WORKSHOP.timeLine}
        </p>
      </div>
      <button
        type="button"
        class="shrink-0 rounded-full border border-white/10 bg-white/5 p-2 text-white/80 hover:text-white hover:bg-white/10 transition-colors min-w-[44px] min-h-[44px] flex items-center justify-center"
        data-close-registration
        aria-label="Close"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
      </button>
    </div>

    <div class="px-6 py-6">
      <WorkshopRegistrationForm idPrefix="modal" variant="panel" showHeader={false} />
    </div>
  </div>
</div>
