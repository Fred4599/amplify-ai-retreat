---
import { WORKSHOP } from '../../config/workshop';

interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div
  class:list={['flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-white/80 font-body text-sm', className]}
  data-workshop-countdown
  data-target={WORKSHOP.startDateIso}
  aria-live="polite"
>
  <span class="text-white/50 uppercase tracking-widest text-xs">Starts in</span>
  <div class="flex items-center gap-2 sm:gap-3 tabular-nums">
    <span data-countdown-days class="font-medium text-white">—</span>
    <span class="text-white/30">:</span>
    <span data-countdown-hours class="font-medium text-white">—</span>
    <span class="text-white/30">:</span>
    <span data-countdown-minutes class="font-medium text-white">—</span>
    <span class="text-white/30 hidden sm:inline">:</span>
    <span data-countdown-seconds class="font-medium text-white hidden sm:inline">—</span>
  </div>
</div>

<script>
  function pad(value: number) {
    return String(value).padStart(2, '0');
  }

  function updateCountdown(el: HTMLElement) {
    const targetIso = el.dataset.target;
    if (!targetIso) return;

    const target = new Date(targetIso).getTime();
    const now = Date.now();
    const diff = Math.max(0, target - now);

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
    const minutes = Math.floor((diff / (1000 * 60)) % 60);
    const seconds = Math.floor((diff / 1000) % 60);

    const daysEl = el.querySelector('[data-countdown-days]');
    const hoursEl = el.querySelector('[data-countdown-hours]');
    const minutesEl = el.querySelector('[data-countdown-minutes]');
    const secondsEl = el.querySelector('[data-countdown-seconds]');

    if (daysEl) daysEl.textContent = `${days}d`;
    if (hoursEl) hoursEl.textContent = `${pad(hours)}h`;
    if (minutesEl) minutesEl.textContent = `${pad(minutes)}m`;
    if (secondsEl) secondsEl.textContent = `${pad(seconds)}s`;

    if (diff === 0) {
      el.querySelector('[data-countdown-days]')!.textContent = 'Live now';
      el.querySelector('[data-countdown-hours]')!.textContent = '';
      el.querySelector('[data-countdown-minutes]')!.textContent = '';
      el.querySelector('[data-countdown-seconds]')!.textContent = '';
    }
  }

  document.querySelectorAll<HTMLElement>('[data-workshop-countdown]').forEach((el) => {
    updateCountdown(el);
    window.setInterval(() => updateCountdown(el), 1000);
  });
</script>
