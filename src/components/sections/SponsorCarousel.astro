---
import { SPONSORS } from '../../config/site';

/** Repeat sponsors so each loop segment fills wide viewports. */
const group = [...SPONSORS, ...SPONSORS, ...SPONSORS];

const logoClass =
  'sponsor-logo relative z-[1] h-11 sm:h-14 w-auto max-w-[10rem] sm:max-w-[12rem] object-contain object-center transition-all duration-300 group-hover:scale-105';
---

<section
  id="partners"
  class="sponsor-section relative w-full self-stretch border-y border-white/10 py-12 sm:py-14"
  aria-label="Event partners"
>
  <p class="text-center text-white/40 text-xs font-body uppercase tracking-[0.2em] mb-8 px-4">
    Supported by
  </p>

  <div class="sponsor-static hidden flex-wrap items-center justify-center gap-6 sm:gap-10 px-4">
    {SPONSORS.map((sponsor) => (
      <a
        href={sponsor.url}
        target="_blank"
        rel="noopener noreferrer"
        class="sponsor-card group"
        aria-label={`Visit ${sponsor.name}`}
      >
        <img
          src={sponsor.logoPath}
          alt={sponsor.name}
          width="180"
          height="56"
          class={logoClass}
          loading="lazy"
          decoding="async"
        />
      </a>
    ))}
  </div>

  <div class="sponsor-marquee relative w-full overflow-hidden">
    <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-16 sm:w-28 bg-gradient-to-r from-black to-transparent" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-16 sm:w-28 bg-gradient-to-l from-black to-transparent" aria-hidden="true"></div>

    <div class="sponsor-track flex w-max items-center gap-10 sm:gap-16">
      <div class="sponsor-group flex shrink-0 items-center gap-10 sm:gap-16">
        {group.map((sponsor) => (
          <a
            href={sponsor.url}
            target="_blank"
            rel="noopener noreferrer"
            class="sponsor-card group"
            aria-label={`Visit ${sponsor.name}`}
          >
            <img
              src={sponsor.logoPath}
              alt={sponsor.name}
              width="180"
              height="56"
              class={logoClass}
              loading="lazy"
              decoding="async"
            />
          </a>
        ))}
      </div>
      <div class="sponsor-group flex shrink-0 items-center gap-10 sm:gap-16" aria-hidden="true">
        {group.map((sponsor) => (
          <a
            href={sponsor.url}
            target="_blank"
            rel="noopener noreferrer"
            tabindex="-1"
            class="sponsor-card group"
          >
            <img
              src={sponsor.logoPath}
              alt=""
              width="180"
              height="56"
              class={logoClass}
              loading="lazy"
              decoding="async"
            />
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .sponsor-card {
    display: flex;
    flex-shrink: 0;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.25rem;
  }

  .sponsor-logo {
    filter: brightness(0) invert(1);
    opacity: 0.7;
  }

  .sponsor-card:hover .sponsor-logo {
    opacity: 1;
  }

  .sponsor-track {
    animation: sponsor-marquee 55s linear infinite;
    will-change: transform;
  }

  @keyframes sponsor-marquee {
    from {
      transform: translate3d(0, 0, 0);
    }
    to {
      transform: translate3d(-50%, 0, 0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sponsor-marquee {
      display: none;
    }

    .sponsor-static {
      display: flex;
    }
  }
</style>
