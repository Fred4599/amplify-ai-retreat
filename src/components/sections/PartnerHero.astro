---
import { eventDatesLine, VENUE } from '../../config/site';
import { MEDIA } from '../../config/media';
import type { Sponsor } from '../../config/site';

interface Props {
  partner: Sponsor;
  badge: string;
  headline: string;
  subheadline: string;
  primaryCta: { href: string; label: string };
  secondaryCta: { href: string; label: string };
  pricing: { retail: string; partner: string; note: string };
  logoSize?: 'wide' | 'square';
}

const {
  partner,
  badge,
  headline,
  subheadline,
  primaryCta,
  secondaryCta,
  pricing,
  logoSize = 'wide',
} = Astro.props;

const logoClass =
  logoSize === 'square'
    ? 'w-[min(55vw,14rem)] sm:w-[min(45vw,16rem)] md:w-[min(38vw,18rem)] h-auto object-contain opacity-95 transition-opacity duration-300 group-hover:opacity-100'
    : 'w-[min(82vw,18rem)] sm:w-[min(72vw,22rem)] md:w-[min(62vw,26rem)] h-auto object-contain opacity-95 transition-opacity duration-300 group-hover:opacity-100';
---

<section id="hero" class="relative w-full min-h-[100svh] overflow-x-hidden">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img
      src={MEDIA.posters.hero}
      alt=""
      class="absolute inset-0 h-full w-full object-cover pointer-events-none"
      fetchpriority="high"
      decoding="async"
    />
    <video
      class="absolute inset-0 h-full w-full object-cover pointer-events-none"
      src={MEDIA.videos.hero}
      poster={MEDIA.posters.hero}
      muted
      loop
      playsinline
      autoplay
      preload="metadata"
    ></video>
    <div class="absolute inset-0 bg-black/40 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-full h-[200px] sm:h-[300px] bg-gradient-to-b from-transparent to-black pointer-events-none"></div>
  </div>

  <div class="hero-copy relative z-30 flex flex-col items-center text-center px-4 sm:px-6 w-full max-w-full min-h-[100svh] pt-24 sm:pt-28 md:pt-32 lg:pt-[150px] pb-10 sm:pb-14">
    <a
      href={partner.url}
      target="_blank"
      rel="noopener noreferrer"
      class="shrink-0 mb-6 sm:mb-8 inline-flex flex-col items-center justify-center transition-transform duration-300 hover:scale-[1.02] group"
      aria-label={`${partner.name} — visit website`}
    >
      <img
        src={partner.logoPath}
        alt={partner.name}
        width="320"
        height="160"
        class={logoClass}
        fetchpriority="high"
        decoding="async"
      />
    </a>

    <div class="shrink-0 mb-6 sm:mb-8 flex flex-col sm:flex-row items-center justify-center gap-2.5 sm:gap-3 w-full px-2 sm:px-1 sm:py-1 sm:pr-4 sm:liquid-glass sm:rounded-full">
      <span class="bg-white text-black rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-wider whitespace-nowrap shrink-0">
        {badge}
      </span>
      <span class="text-white/85 font-body text-sm font-medium text-center sm:text-left leading-snug max-w-[18rem] sm:max-w-none">
        {eventDatesLine()} · Logan, Utah · 3-Day Implementation Retreat
      </span>
    </div>

    <h1 class="shrink-0 text-[2.75rem] sm:text-6xl md:text-7xl lg:text-[7.5rem] font-heading italic text-white max-w-5xl tracking-tight text-center px-1 leading-[1.05]">
      Amplify AI Retreat
    </h1>

    <h2 class="shrink-0 mt-5 sm:mt-6 text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-[4.75rem] text-white/90 font-heading italic tracking-tight text-center max-w-4xl leading-[1.08]">
      {headline}
    </h2>

    <p class="shrink-0 mt-6 sm:mt-8 text-base sm:text-lg md:text-xl text-white/85 font-body font-light leading-relaxed max-w-2xl px-1 text-center">
      {subheadline}
    </p>

    <div class="shrink-0 mt-6 sm:mt-7 flex flex-col items-center gap-2 px-2">
      <p class="text-white/55 font-body text-xs sm:text-sm uppercase tracking-widest">
        {pricing.note}
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3 sm:gap-4">
        <span class="text-white/45 font-body text-xl sm:text-2xl line-through decoration-white/35">
          {pricing.retail}
        </span>
        <span class="text-white font-heading italic text-3xl sm:text-4xl tracking-tight">
          {pricing.partner}
        </span>
      </div>
      <p class="text-white/50 font-body text-sm font-light max-w-md">
        Save $1,000 — reserved exclusively for the {partner.name} community.
      </p>
    </div>

    <p class="shrink-0 mt-4 text-sm text-white/50 font-body font-light tracking-wide">
      {VENUE.name} · Logan, Utah
    </p>

    <div class="shrink-0 flex flex-col sm:flex-row items-stretch sm:items-center gap-3 sm:gap-4 mt-8 sm:mt-10 w-full sm:w-auto max-w-sm sm:max-w-none px-2 sm:px-0">
      <a
        href={primaryCta.href}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-white text-black hover:bg-white/90 transition-colors duration-300 rounded-full px-6 py-3.5 flex items-center justify-center gap-2 font-medium text-sm min-h-[44px]"
      >
        {primaryCta.label}
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70" aria-hidden="true"><path d="M7 7h10v10"></path><path d="M7 17 17 7"></path></svg>
      </a>
      <a
        href={secondaryCta.href}
        target="_blank"
        rel="noopener noreferrer"
        class="liquid-glass-strong hover:scale-105 transition-transform duration-300 rounded-full px-6 py-3.5 flex items-center justify-center gap-2 text-white font-medium text-sm min-h-[44px]"
      >
        {secondaryCta.label}
      </a>
    </div>
  </div>
</section>
