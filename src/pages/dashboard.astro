---
import BaseLayout from '../layouts/BaseLayout.astro';
import ApplyNavbar from '../components/ApplyNavbar.astro';
import DashboardApp from '../components/attendee/DashboardApp';
---

<BaseLayout
  title="Dashboard — Amplify AI Retreat"
  description="Your Amplify AI Retreat attendee dashboard."
  path="/dashboard"
  noindex={true}
>
  <ApplyNavbar />

  <main
    id="main-content"
    class="min-h-screen w-full max-w-full overflow-x-hidden pt-[max(6.5rem,env(safe-area-inset-top))] pb-[max(4rem,env(safe-area-inset-bottom))] px-4 sm:px-6 relative"
  >
    <div class="absolute inset-0 bg-gradient-to-b from-white/[0.03] via-transparent to-transparent pointer-events-none"></div>
    <div class="relative max-w-3xl mx-auto w-full">
      <DashboardApp client:load />
    </div>
  </main>
</BaseLayout>
