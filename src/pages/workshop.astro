---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkshopNavbar from '../components/WorkshopNavbar.astro';
import WorkshopCountdown from '../components/workshop/WorkshopCountdown.astro';
import WorkshopRegistrationForm from '../components/workshop/WorkshopRegistrationForm.astro';
import WorkshopRegistrationModal from '../components/workshop/WorkshopRegistrationModal.astro';
import {
  WORKSHOP,
  WORKSHOP_HOSTS,
  WORKSHOP_PRESENTER,
  WORKSHOP_PROOF_STATS,
  WORKSHOP_TESTIMONIALS,
  WORKSHOP_OUTCOMES,
} from '../config/workshop';
import { MEDIA } from '../config/media';

const webhook = import.meta.env.PUBLIC_WEBINAR_WEBHOOK ?? '';

const pageTitle = `${WORKSHOP.title} — Free Webinar | Amplify AI`;
const pageDescription = WORKSHOP.description;
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  path={WORKSHOP.path}
  structuredData="workshop"
>
  <WorkshopNavbar />

  <main id="main-content" class="bg-black relative w-full max-w-full overflow-x-hidden">
    <!-- Hero -->
    <section id="hero-register" class="relative w-full min-h-[min(100svh,900px)] overflow-x-hidden">
      <div class="absolute inset-0 z-0" aria-hidden="true">
        <img
          src={MEDIA.posters.hero}
          alt=""
          class="absolute inset-0 h-full w-full object-cover pointer-events-none"
          fetchpriority="high"
          decoding="async"
        />
        <video
          class="absolute inset-0 h-full w-full object-cover pointer-events-none"
          src={MEDIA.videos.hero}
          poster={MEDIA.posters.hero}
          muted
          loop
          playsinline
          autoplay
          preload="metadata"
        ></video>
        <div class="absolute inset-0 bg-black/50 pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-full h-[200px] sm:h-[300px] bg-gradient-to-b from-transparent to-black pointer-events-none"></div>
      </div>

      <div class="hero-copy relative z-30 flex flex-col items-center text-center px-4 sm:px-6 w-full max-w-full min-h-[min(100svh,900px)] pt-24 sm:pt-28 md:pt-32 lg:pt-[150px] pb-16 sm:pb-20">
        <a
          href={WORKSHOP_PRESENTER.url}
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 mb-5 sm:mb-6 inline-flex flex-wrap items-center justify-center gap-2.5 sm:gap-3 text-sm sm:text-base text-white/75 hover:text-white font-body font-medium tracking-wide transition-colors group"
          aria-label={`Presented by ${WORKSHOP_PRESENTER.name} — visit website`}
        >
          <span>Presented by</span>
          <img
            src={WORKSHOP_PRESENTER.logoPath}
            alt=""
            width="38"
            height="38"
            class="h-8 sm:h-9 w-auto shrink-0 object-contain opacity-90 transition-all duration-300 group-hover:opacity-100 group-hover:scale-105"
            decoding="async"
            aria-hidden="true"
          />
          <span>{WORKSHOP_PRESENTER.name}</span>
        </a>

        <div class="shrink-0 mb-4 sm:mb-5 flex flex-col items-center justify-center gap-3 w-full px-2">
          <div class="flex flex-col sm:flex-row items-center justify-center gap-2.5 sm:gap-3 w-full px-1 sm:py-1 sm:pr-4 sm:liquid-glass sm:rounded-full">
            <span class="bg-white text-black rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-wider whitespace-nowrap shrink-0">
              {WORKSHOP.subtitle}
            </span>
            <span class="text-white/85 font-body text-sm font-medium text-center sm:text-left leading-snug max-w-[20rem] sm:max-w-none">
              {WORKSHOP.dateLine} · {WORKSHOP.timeLine}
            </span>
          </div>
          <WorkshopCountdown />
        </div>

        <h1 class="shrink-0 text-[2.5rem] sm:text-5xl md:text-6xl lg:text-[5.5rem] font-heading italic text-white max-w-4xl tracking-tight text-center px-1 leading-[1.05]">
          {WORKSHOP.title}
        </h1>

        <p class="shrink-0 mt-5 sm:mt-6 text-2xl sm:text-3xl md:text-4xl text-white/90 font-heading italic tracking-tight text-center max-w-3xl leading-[1.12]">
          {WORKSHOP.tagline}
        </p>

        <p class="shrink-0 mt-6 sm:mt-8 text-base sm:text-lg md:text-xl text-white/80 font-body font-light leading-relaxed max-w-2xl px-1 text-center">
          {WORKSHOP.description}
        </p>

        <div class="shrink-0 mt-6 sm:mt-8 w-full max-w-xl px-1">
          <WorkshopRegistrationForm idPrefix="hero" variant="hero" showHeader={false} webhook={webhook} />
        </div>

        <div class="shrink-0 mt-6 flex flex-wrap items-center justify-center gap-3 sm:gap-4 max-w-2xl">
          {WORKSHOP_PROOF_STATS.map((stat) => (
            <div class="liquid-glass rounded-full px-4 py-2 text-center">
              <span class="block text-white font-heading italic text-lg leading-none">{stat.value}</span>
              <span class="block text-white/55 font-body text-[10px] uppercase tracking-wider mt-1">
                {stat.label}
              </span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Outcomes -->
    <section class="relative z-10 bg-black w-full py-20 sm:py-28 px-4 sm:px-6">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-14 sm:mb-16">
          <p class="liquid-glass inline-block rounded-full px-4 py-1.5 mb-6">
            <span class="text-white text-xs font-medium font-body uppercase tracking-wider">
              During This Webinar
            </span>
          </p>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-heading italic text-white tracking-tight">
            Turn possibility into practical next steps
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-5">
          {WORKSHOP_OUTCOMES.map((outcome, index) => (
            <article class:list={[
              'rounded-3xl border border-white/10 bg-white/[0.04] backdrop-blur-sm p-6 sm:p-7 flex items-start gap-4',
              index === WORKSHOP_OUTCOMES.length - 1 ? 'md:col-span-2' : '',
            ]}>
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-white text-black font-heading italic text-sm">
                {String(index + 1).padStart(2, '0')}
              </span>
              <p class="text-white/75 font-body font-light text-base sm:text-lg leading-relaxed">
                {outcome}
              </p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Social proof -->
    <section class="relative z-10 bg-black w-full py-16 sm:py-20 px-4 sm:px-6 border-t border-white/5">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-10 sm:mb-12">
          <p class="liquid-glass inline-block rounded-full px-4 py-1.5 mb-6">
            <span class="text-white text-xs font-medium font-body uppercase tracking-wider">
              Real Results
            </span>
          </p>
          <h2 class="text-3xl sm:text-4xl font-heading italic text-white tracking-tight">
            The same implementation mindset — applied to your business
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-5 sm:gap-6">
          {WORKSHOP_TESTIMONIALS.map((item) => (
            <article class="rounded-3xl border border-white/10 bg-white/[0.04] backdrop-blur-sm p-6 sm:p-8 flex flex-col">
              <div class="mb-5">
                <span class="text-3xl font-heading italic text-white">{item.metric}</span>
                <span class="block text-white/45 font-body text-[10px] uppercase tracking-widest mt-1">
                  {item.metricLabel}
                </span>
              </div>
              <blockquote class="text-white/70 font-body font-light text-sm sm:text-base leading-relaxed flex-1">
                “{item.quote}”
              </blockquote>
              <p class="text-white/40 font-body text-xs uppercase tracking-widest mt-5">
                {item.attribution}
              </p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Hosts -->
    <section class="relative z-10 bg-black w-full py-20 sm:py-28 px-4 sm:px-6 border-t border-white/5">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-12 sm:mb-14">
          <p class="liquid-glass inline-block rounded-full px-4 py-1.5 mb-6">
            <span class="text-white text-xs font-medium font-body uppercase tracking-wider">
              Your Hosts
            </span>
          </p>
          <h2 class="text-3xl sm:text-4xl md:text-5xl font-heading italic text-white tracking-tight">
            Live with Tony, Bill &amp; Braydon
          </h2>
          <p class="text-white/60 font-body font-light text-base sm:text-lg leading-relaxed max-w-2xl mx-auto mt-5">
            Three guides — AI implementation, mindset, and business strategy — sharing the plays
            they use to help owners turn AI into measurable growth.
          </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 sm:gap-6">
          {WORKSHOP_HOSTS.map((host) => (
            <article class="flex flex-col items-center text-center rounded-3xl border border-white/10 bg-white/[0.04] backdrop-blur-sm p-6 sm:p-8">
              <img
                src={host.photo}
                alt={host.name}
                width="128"
                height="128"
                loading="lazy"
                decoding="async"
                class="rounded-full w-24 h-24 sm:w-28 sm:h-28 object-cover mb-5 border border-white/10"
              />
              <p class="text-white/40 font-body text-[10px] uppercase tracking-widest mb-2">
                {host.role}
              </p>
              <h3 class="text-xl sm:text-2xl font-heading italic text-white tracking-tight">
                {host.name}
              </h3>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- Who it's for -->
    <section class="relative z-10 bg-black w-full py-16 sm:py-20 px-4 sm:px-6 border-t border-white/5">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-heading italic text-white tracking-tight mb-6">
          No AI expertise required
        </h2>
        <p class="text-white/60 font-body font-light text-base sm:text-lg leading-relaxed">
          {WORKSHOP.audienceDescription}
        </p>
        <button
          type="button"
          data-open-registration
          class="mt-8 liquid-glass-strong hover:scale-105 transition-transform duration-300 rounded-full px-8 py-3.5 inline-flex items-center justify-center gap-2 text-white font-medium text-sm min-h-[44px]"
        >
          Reserve Your Spot
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="opacity-70" aria-hidden="true"><path d="M7 7h10v10"></path><path d="M7 17 17 7"></path></svg>
        </button>
      </div>
    </section>

    <!-- Registration -->
    <section id="register" class="relative z-10 bg-black w-full py-20 sm:py-28 px-4 sm:px-6">
      <div class="absolute inset-0 bg-gradient-to-b from-white/[0.02] via-transparent to-transparent pointer-events-none"></div>

      <div class="relative max-w-xl mx-auto w-full">
        <div class="rounded-3xl overflow-hidden w-full border border-white/10 bg-white/[0.06] backdrop-blur-xl shadow-2xl">
          <WorkshopRegistrationForm idPrefix="bottom" variant="panel" webhook={webhook} />
        </div>

        <p class="text-center text-white/40 font-body text-xs mt-8 max-w-md mx-auto leading-relaxed">
          Interested in going deeper? The Amplify AI Retreat is a 3-day hands-on implementation
          experience — <a href="/" class="text-white/60 hover:text-white underline underline-offset-2 transition-colors">learn more</a>.
        </p>
      </div>
    </section>
  </main>

  <WorkshopRegistrationModal webhook={webhook} />

  <script>
    import { submitWebinarRegistration } from '../lib/form-submissions';

    const modal = document.getElementById('registration-modal');

    function openRegistration() {
      if (!modal) return;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      modal.hidden = false;
      document.body.style.overflow = 'hidden';
      const firstInput = modal.querySelector('input');
      window.setTimeout(() => firstInput?.focus(), 50);
    }

    function closeRegistration() {
      if (!modal) return;
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      modal.hidden = true;
      document.body.style.overflow = '';
    }

    document.querySelectorAll('[data-open-registration]').forEach((trigger) => {
      trigger.addEventListener('click', (event) => {
        event.preventDefault();
        openRegistration();
      });
    });

    document.querySelectorAll('[data-close-registration]').forEach((trigger) => {
      trigger.addEventListener('click', closeRegistration);
    });

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && modal && !modal.hidden) closeRegistration();
    });

    function showSuccess(form: HTMLFormElement) {
      const prefix = form.id.replace('-form', '');
      form.hidden = true;
      const success = document.getElementById(`${prefix}-success`);
      if (success) {
        success.classList.remove('hidden');
        success.hidden = false;
      }
      closeRegistration();
    }

    function showError(form: HTMLFormElement, message: string) {
      const prefix = form.id.replace('-form', '');
      const errorEl = document.getElementById(`${prefix}-error`);
      const submitBtn = document.getElementById(`${prefix}-submit`) as HTMLButtonElement | null;
      if (errorEl) {
        errorEl.textContent = message;
        errorEl.classList.remove('hidden');
        errorEl.hidden = false;
      }
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Register Free';
      }
    }

    document.querySelectorAll<HTMLFormElement>('[data-webinar-form]').forEach((form) => {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        const prefix = form.id.replace('-form', '');
        const submitBtn = document.getElementById(`${prefix}-submit`) as HTMLButtonElement | null;
        const errorEl = document.getElementById(`${prefix}-error`);
        const webhook = form.dataset.webhook ?? '';

        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Registering…';
        }
        if (errorEl) {
          errorEl.classList.add('hidden');
          errorEl.hidden = true;
        }

        const data = new FormData(form);
        const result = await submitWebinarRegistration({
          webhook,
          payload: {
            fullName: String(data.get('fullName') ?? ''),
            email: String(data.get('email') ?? ''),
            phone: '',
            company: '',
            submittedAt: new Date().toISOString(),
          },
        });

        if (!result.ok) {
          showError(
            form,
            result.error.includes('not configured')
              ? result.error
              : 'Something went wrong. Please try again or email us directly.',
          );
          return;
        }

        document.querySelectorAll<HTMLFormElement>('[data-webinar-form]').forEach((otherForm) => {
          showSuccess(otherForm);
        });
      });
    });
  </script>
</BaseLayout>
