# n8n webhook for /workshop webinar registration (browser → n8n → GHL)
PUBLIC_WEBINAR_WEBHOOK=https://sitespice.app.n8n.cloud/webhook/amplify-webinar-registration

# Jets & Capital partner landing page (/jets-and-capital)
PUBLIC_JETS_CAPITAL_CHECKOUT_URL=https://keepelevated.com/amplify-payment-link?am_id=alecatkinson4403
