# Production site URL (required for canonical URLs, sitemap, and Open Graph)
PUBLIC_SITE_URL=https://retreat.amplifyai.dev

# n8n webhook for /apply form submissions (set in Vercel Environment Variables)
PUBLIC_APPLICATION_WEBHOOK=https://sitespice.app.n8n.cloud/webhook/amplify-retreat-application

# n8n webhook for /workshop webinar registration
PUBLIC_WEBINAR_WEBHOOK=https://sitespice.app.n8n.cloud/webhook/amplify-webinar-registration
